# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

setopt +o nomatch

# Homebrew環境設定
eval "$(/opt/homebrew/bin/brew shellenv)"

# zsh補完システムの初期化
autoload -Uz compinit
compinit

# mise (ランタイム管理)
eval "$(mise activate zsh)"

# Powerlevel10k プロンプト
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme

# Sheldon (高速プラグイン管理)
eval "$(sheldon source)"



## [Completion]
## Completion scripts setup. Remove the following line to uninstall
[[ -f /Users/owaki-kengo/.dart-cli-completion/zsh-config.zsh ]] && . /Users/owaki-kengo/.dart-cli-completion/zsh-config.zsh || true
## [/Completion]




# デフォルトエディタ
export EDITOR="fresh"
export VISUAL="fresh"

export ANDROID_HOME=~/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/tools:$ANDROID_HOME/tools/bin:$ANDROID_HOME/platform-tools
export NDK_HOME=$HOME/Library/Android/sdk/ndk/29.0.13599879

# Cargo (Rust) 環境設定
. "$HOME/.cargo/env"
export PATH="$HOME/.cargo/bin:$PATH"

# Added by Antigravity
export PATH="/Users/owaki-kengo/.antigravity/antigravity/bin:$PATH"

# Carapace補完
export CARAPACE_BRIDGES="zsh,fish,bash,inshellisense"
zstyle ":completion:*" format $"\e[2;37mCompleting %d\e[m"
source <(carapace _carapace)

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Zoxide initialization
eval "$(zoxide init zsh)"

# 非対話型シェルでは enhancd を無効化（Claude Code対応）
if [[ ! -o interactive ]]; then
  unfunction cd 2>/dev/null
  alias cd='builtin cd'
fi

# Yazi file manager function (with cd capability)
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
